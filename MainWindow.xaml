<Window x:Class="Yak130Controller.MainWindow" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        Title="Як-130 Контроллер" Height="600" Width="800" Background="#F0F0F0">
    <Grid>
        <StackPanel Margin="20">
            <!-- COM Port Selection -->
            <GroupBox Header="Подключение COM-Порта" FontSize="14" FontWeight="Bold" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Label Content="Выберите порт:" Width="100"/>
                        <ComboBox Name="ComPortComboBox" Width="150" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <Button Name="RefreshButton" Content="Обновить" Width="100" Margin="10,0,0,0" Click="RefreshButton_Click"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Name="ConnectButton" Content="Подключиться" Width="100" Click="ConnectButton_Click" Background="#4CAF50" Foreground="White"/>
                        <Button Name="DisconnectButton" Content="Отключиться" Width="100" Margin="10,0,0,0" Click="DisconnectButton_Click" Background="#f44336" Foreground="White"/>
                    </StackPanel>
                    <Label Name="StatusLabel" Content="Статус: Отключено" Margin="0,10,0,0" Foreground="#FF6200"/>
                </StackPanel>
            </GroupBox>

            <!-- Input Parameters -->
            <GroupBox Header="Входные Параметры" FontSize="14" FontWeight="Bold" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Label Content="Скорость (м/с):" Width="150"/>
                        <TextBox Name="SpeedTextBox" Width="150" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Label Content="Высота (м):" Width="150"/>
                        <TextBox Name="AltitudeTextBox" Width="150" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Label Content="Угол атаки (°):" Width="150"/>
                        <TextBox Name="AngleTextBox" Width="150" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Control Surfaces -->
            <GroupBox Header="Управление Рулями" FontSize="14" FontWeight="Bold" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Label Content="Элеронов (°):" Width="150"/>
                        <Slider Name="AileronSlider" Width="200" Minimum="-30" Maximum="30" Value="0" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <Label Name="AileronLabel" Content="0°" Width="50" Margin="10,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Label Content="Закрылков (°):" Width="150"/>
                        <Slider Name="FlapSlider" Width="200" Minimum="0" Maximum="45" Value="0" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <Label Name="FlapLabel" Content="0°" Width="50" Margin="10,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Label Content="Руль направления (°):" Width="150"/>
                        <Slider Name="RudderYawSlider" Width="200" Minimum="-30" Maximum="30" Value="0" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <Label Name="RudderYawLabel" Content="0°" Width="50" Margin="10,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Label Content="Руль высоты (°):" Width="150"/>
                        <Slider Name="RudderPitchSlider" Width="200" Minimum="-30" Maximum="30" Value="0" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <Label Name="RudderPitchLabel" Content="0°" Width="50" Margin="10,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Results -->
            <GroupBox Header="Результаты Расчёта" FontSize="14" FontWeight="Bold" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Label Content="Подъёмная сила:" Width="150"/>
                        <Label Name="LiftLabel" Content="0.00 N" Width="150"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Label Content="Сопротивление:" Width="150"/>
                        <Label Name="DragLabel" Content="0.00 N" Width="150"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Label Content="Тяга:" Width="150"/>
                        <Label Name="ThrustLabel" Content="0.00 N" Width="150"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Action Button -->
            <Button Name="CalculateButton" Content="Рассчитать и Отправить" Height="40" Background="#2196F3" Foreground="White" FontSize="14" Click="CalculateButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
